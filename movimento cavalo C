#include <stdio.h>

int main() {

    // ================================
    // Movimento do Cavalo
    // ================================

    // Definindo quantidade de movimentos
    int movimentosBaixo = 2;
    int movimentosEsquerda = 1;

    // Loop externo (for) para movimento vertical (para baixo)
    // Este loop controla as "duas casas para baixo"
    for (int i = 0; i < movimentosBaixo; i++) {
        printf("Baixo\n");
    }

    // Loop interno (while) para movimento horizontal (para a esquerda)
    // Este loop controla a "uma casa para a esquerda"
    int j = 0;
    while (j < movimentosEsquerda) {
        printf("Esquerda\n");
        j++;
    }

    // Linha em branco para separar dos outros movimentos
    printf("\n");

    return 0;
}
